---
import { profile } from "../data/profile";
import MusicWidget from "./MusicWidget.astro";

const email = profile.contact.find((item) => item.label === "Email");
const github = profile.contact.find((item) => item.label === "GitHub");
const linkedin = profile.contact.find((item) => item.label === "LinkedIn");
const [titleLead, titleRest] = profile.title.split(" I like ");
---

<section class="profile-panel min-h-[100svh] bg-paper px-5 py-5 text-ink sm:px-8 lg:h-[100vh] lg:overflow-hidden lg:px-10 lg:py-8">
  <div class="mx-auto grid min-h-[calc(100svh-2.5rem)] max-w-7xl gap-8 lg:h-full lg:min-h-0 lg:grid-cols-[minmax(20rem,0.82fr)_minmax(0,1.18fr)] lg:gap-12">
    <div class="relative flex min-h-[34rem] flex-col items-end text-right lg:min-h-0">
      <header class="flex w-full shrink-0 justify-end">
        <div class="min-w-0 text-right">
          <div class="flex items-center justify-end gap-3">
            <p class="font-mono text-[10px] uppercase tracking-[0.28em] text-ink/35">Portfolio / V0</p>
            <span class="h-3 w-3 rounded-full bg-accent" aria-hidden="true"></span>
          </div>
          <h1 class="mt-7 text-5xl font-semibold leading-[0.92] tracking-normal text-ink sm:text-6xl lg:text-[clamp(4rem,5.6vw,6.25rem)]">
            {profile.name}
          </h1>
        </div>
      </header>

      <div class="mt-8 max-w-xl">
        <p class="max-w-md text-lg font-semibold leading-7 text-ink sm:text-xl">
          {titleLead}
          {titleRest && <><br />I like {titleRest}</>}
        </p>
        <div class="mt-5 border-r border-line pr-4">
          <p class="font-mono text-[12px] uppercase leading-5 tracking-[0.16em] text-ink/48">
            {profile.education}
          </p>
          <p class="mt-1 font-mono text-[11px] uppercase leading-5 tracking-[0.16em] text-accent">
            {profile.availability}
          </p>
        </div>
      </div>

      <div class="profile-music profile-music-header pointer-events-auto absolute -right-5 bottom-36 z-10 hidden sm:block lg:bottom-32">
        <MusicWidget />
      </div>

      <footer class="profile-footer mt-auto flex w-full shrink-0 justify-end border-t border-line pt-7">
        <div class="flex min-w-0 flex-col items-end">
          <p class="text-right font-mono text-[11px] font-semibold uppercase tracking-[0.2em] text-ink/45">Contact</p>
          <div class="mt-3 flex min-w-0 items-center justify-end gap-6">
            {email && (
              <a href={email.href} class="group/contact min-w-0 text-ink/70 transition hover:text-ink">
                <span class="flex min-w-0 items-center justify-end gap-2.5">
              <svg class="h-7 w-7 shrink-0 text-ink/60 transition group-hover/contact:text-accent" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.85" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
              </svg>
              <span class="truncate text-base font-semibold leading-none">{email.href.replace("mailto:", "")}</span>
            </span>
              </a>
            )}

            <div class="flex shrink-0 items-center gap-4">
              {github && (
                <a href={github.href} target="_blank" rel="noopener noreferrer" aria-label="GitHub" class="grid h-12 w-12 place-items-center text-ink/60 transition hover:text-accent">
                  <svg class="h-9 w-9" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2z"/>
                  </svg>
                </a>
              )}
              {linkedin && (
                <a href={linkedin.href} target="_blank" rel="noopener noreferrer" aria-label="LinkedIn" class="grid h-12 w-12 place-items-center text-ink/60 transition hover:text-accent">
                  <svg class="h-9 w-9" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                  </svg>
                </a>
              )}
            </div>
          </div>
        </div>
      </footer>
    </div>

    <div class="profile-scroll min-h-0 space-y-8 border-t border-line pt-7 lg:h-full lg:overflow-y-auto lg:border-t-0 lg:border-l lg:pl-10 lg:pr-8 lg:pt-8">
      <section>
        <h2 class="font-mono text-[11px] uppercase tracking-[0.18em] text-ink/60">Experience</h2>
        <ol class="mt-4 divide-y divide-line border-b border-line">
          {profile.experience.map((role) => (
            <li class="grid gap-2 py-4 first:pt-0 sm:grid-cols-[minmax(0,1fr)_8rem] sm:gap-6">
              <div class="min-w-0">
                <div class="flex min-w-0 flex-wrap items-center gap-x-2 gap-y-1">
                  {role.logo === "red-cross" ? (
                    <span class="profile-logo profile-logo-cross" aria-hidden="true">
                      <svg viewBox="0 0 16 16">
                        <path d="M6.2 1.8h3.6v4.4h4.4v3.6H9.8v4.4H6.2V9.8H1.8V6.2h4.4z" fill="currentColor" />
                      </svg>
                    </span>
                  ) : (
                    <img class="profile-logo" src={role.logo} alt="" loading="lazy" decoding="async" aria-hidden="true" />
                  )}
                  {role.name === "Primate.sh" ? (
                    <a
                      class="preview-trigger text-lg font-semibold leading-tight text-ink underline decoration-ink/25 underline-offset-3 transition hover:text-accent"
                      href={role.url}
                      target="_blank"
                      rel="noopener noreferrer"
                      data-url={role.url}
                      data-name={role.name}
                    >{role.name}</a>
                  ) : (
                    <span class="text-lg font-semibold leading-tight text-ink">{role.name}</span>
                  )}
                  <span class="text-base leading-tight text-ink/58">{role.role.replace("- ", "")}</span>
                </div>
                <p class="mt-2 max-w-2xl text-base leading-6 text-ink/72">{role.description}</p>
              </div>
              <p class="font-mono text-[11px] uppercase tracking-[0.15em] text-ink/38 sm:pr-6 sm:text-right">
                {role.name === "Primate.sh" ? "Current" : role.name === "Canadian Red Cross" ? "FW 25/26" : role.period.replace(" — ", " - ")}
              </p>
            </li>
          ))}
        </ol>
      </section>

      <section class="space-y-8">
        <div>
          <h2 class="font-mono text-[11px] uppercase tracking-[0.18em] text-ink/60">Projects</h2>
          <ol class="mt-4 space-y-5">
            {profile.projects.map((project) => (
              <li>
                <a
                  class="group/project inline-flex min-w-0 items-baseline gap-1 text-lg font-semibold leading-tight text-ink transition-colors hover:text-accent"
                  href={project.url}
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  <span>{project.name}</span>
                  <svg class="h-3.5 w-3.5 translate-y-[0.08em] text-ink/35 transition-colors group-hover/project:text-accent/80" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.1" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M7 17 17 7" />
                    <path d="M9 7h8v8" />
                  </svg>
                </a>
                <p class="mt-1 text-base leading-6 text-ink/72">{project.description}</p>
                {project.prizes && (
                  <ul class="mt-2 space-y-1">
                    {project.prizes.map((prize) => (
                      <li class="flex min-w-0 flex-wrap items-center gap-x-2 gap-y-1">
                        <span class="inline-flex shrink-0 items-center gap-1.5 font-mono text-[12px] uppercase tracking-widest text-ink/50">
                          <img class="prize-logo" src={prize.logo} alt="" loading="lazy" decoding="async" aria-hidden="true" />
                          <span>{prize.name}</span>
                        </span>
                        <span class="min-w-0 flex-1 text-sm leading-5 text-ink/70">{prize.note}</span>
                      </li>
                    ))}
                  </ul>
                )}
              </li>
            ))}
          </ol>
        </div>

        <div class="border-t border-line pt-7">
          <h2 class="font-mono text-[11px] uppercase tracking-[0.18em] text-ink/60">Research</h2>
          <ol class="mt-4 space-y-5">
            {profile.research.map((paper) => (
              <li>
                {paper.url ? (
                  <a href={paper.url} target="_blank" rel="noopener noreferrer" class="group/project inline-flex min-w-0 items-baseline gap-1 text-lg font-semibold leading-tight text-ink transition-colors hover:text-accent">
                    <span>{paper.title}</span>
                    <svg class="h-3.5 w-3.5 translate-y-[0.08em] text-ink/35 transition-colors group-hover/project:text-accent/80" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.1" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <path d="M7 17 17 7" />
                      <path d="M9 7h8v8" />
                    </svg>
                  </a>
                ) : (
                  <span class="text-lg font-semibold leading-tight text-ink">{paper.title}</span>
                )}
                <p class="mt-1 text-base leading-6 text-ink/72">{paper.description}</p>
                <ul class="mt-2 space-y-1">
                  {paper.venues.map((venue) => (
                    <li class="flex min-w-0 flex-wrap items-center gap-x-2 gap-y-1">
                      <span class="inline-flex shrink-0 items-center gap-1.5 font-mono text-[12px] uppercase tracking-widest text-ink/50">
                        <img class="venue-logo" src={venue.logo} alt="" loading="lazy" decoding="async" aria-hidden="true" />
                        <span>{venue.name}</span>
                      </span>
                      <span class="min-w-0 flex-1 text-sm leading-5 text-ink/70">{venue.note}</span>
                    </li>
                  ))}
                </ul>
              </li>
            ))}
          </ol>
        </div>
      </section>
    </div>
  </div>

  <div
    id="site-preview"
    class="pointer-events-none fixed z-50 overflow-hidden rounded-sm border border-line bg-paper shadow-xl"
    style="opacity:0; transform: scale(0.88) translateX(-50%) translateY(-100%); transition: opacity 180ms ease, transform 240ms cubic-bezier(0.34,1.56,0.64,1); top:0; left:0; width:200px;"
  >
    <img id="site-preview-img" src="" alt="" class="block h-31.25 w-50 object-cover" />
  </div>

  <script>
    const tooltip = document.getElementById("site-preview") as HTMLElement;
    const tooltipImg = document.getElementById("site-preview-img") as HTMLImageElement;
    let timer: ReturnType<typeof setTimeout> | null = null;

    const microlinkUrl = (url: string) =>
      `https://api.microlink.io/?url=${encodeURIComponent(url)}&screenshot=true&meta=false&embed=screenshot.url&colorScheme=light`;

    const show = (el: HTMLElement) => {
      const url = el.dataset.url ?? "";
      const name = el.dataset.name ?? "";
      tooltipImg.src = microlinkUrl(url);
      tooltipImg.alt = name;

      const rect = el.getBoundingClientRect();
      const tooltipWidth = tooltip.offsetWidth || 200;
      const gutter = 12;
      const centeredLeft = rect.left + rect.width / 2;
      const clampedLeft = Math.min(
        window.innerWidth - tooltipWidth / 2 - gutter,
        Math.max(tooltipWidth / 2 + gutter, centeredLeft)
      );
      const placeBelow = rect.top < 160;

      tooltip.style.left = `${clampedLeft}px`;
      tooltip.style.top = `${placeBelow ? rect.bottom + 12 : rect.top - 12}px`;
      tooltip.style.opacity = "1";
      tooltip.style.transform = `scale(1) translateX(-50%) translateY(${placeBelow ? "0" : "-100%"})`;
    };

    const hide = () => {
      tooltip.style.opacity = "0";
      tooltip.style.transform = "scale(0.88) translateX(-50%) translateY(-100%)";
    };

    tooltipImg.addEventListener("error", hide);

    document.querySelectorAll<HTMLElement>(".preview-trigger").forEach((el) => {
      el.addEventListener("mouseenter", () => {
        if (timer) clearTimeout(timer);
        timer = setTimeout(() => show(el), 300);
      });
      el.addEventListener("mouseleave", () => {
        if (timer) clearTimeout(timer);
        hide();
      });
    });
  </script>
</section>
