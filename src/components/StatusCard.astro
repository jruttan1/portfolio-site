---
import { status } from "../data/status";
---

<section class="status-card flex flex-col overflow-hidden border border-line p-4">
  <div class="flex flex-wrap items-start justify-between gap-3">
    <div>
      <div class="flex items-center gap-2">
        <span class="relative flex h-3 w-3" aria-label="Online status">
          <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-accent-2 opacity-35"></span>
          <span class="relative inline-flex h-3 w-3 rounded-full border border-white bg-accent-2"></span>
        </span>
        <p class="font-mono text-[11px] uppercase tracking-[0.18em] text-accent">{status.label}</p>
      </div>
    </div>
    <span class="border border-line px-2.5 py-1 font-mono text-[11px] text-ink/55">{status.branch}</span>
  </div>
  <ol class="mt-4 divide-y divide-line border-y border-line lg:mt-3">
    {status.commits.map((commit) => (
      <li class="grid grid-cols-[4.25rem_1fr] gap-3 py-3 lg:py-2">
        <span class="font-mono text-[11px] text-ink/45">{commit.hash}</span>
        <div>
          <p class="text-sm font-medium leading-5 text-ink">{commit.message}</p>
          <p class="mt-1 font-mono text-[11px] uppercase tracking-[0.12em] text-ink/45">{commit.meta}</p>
        </div>
      </li>
    ))}
  </ol>
  <div class="mt-4 flex items-end justify-between gap-4">
    <p class="pb-1 font-mono text-[11px] uppercase tracking-[0.14em] text-ink/45">{status.repo} · latest local activity</p>
  </div>
</section>
