---
import { movies } from "../data/movies";

const stars = (rating: number) => "★★★★★".slice(0, Math.floor(rating)) + (rating % 1 ? "½" : "");
---

<section class="letterboxd-card flex flex-col border border-line bg-transparent px-5 py-5 lg:h-full lg:min-h-0 lg:overflow-hidden">
  <div class="shrink-0 flex items-center justify-between gap-4">
    <h2 class="font-mono text-[13px] uppercase tracking-[0.2em] text-ink/35">Recently watched</h2>
  </div>

  <div class="grid flex-1 grid-cols-3 items-center gap-3 py-4">
    {movies.map((movie) => (
      <article class="flex min-w-0 flex-col items-center text-center">
        <div class:list={["aspect-[2/3] w-full max-w-[9.5rem] rounded-[3px]", movie.palette]} aria-hidden="true"></div>
        <div class="mt-2 w-full min-w-0">
          <h3 class="truncate text-sm font-medium leading-none text-ink/70">{movie.title}</h3>
        </div>
        <div class="mt-2 flex w-full justify-center">
          <p class="whitespace-nowrap text-lg font-semibold leading-none text-[#b25332]" aria-label={`${movie.rating} stars`}>{stars(movie.rating)}</p>
        </div>
      </article>
    ))}
  </div>
</section>
