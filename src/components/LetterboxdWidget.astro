---
import { movies } from "../data/movies";

const stars = (rating: number) => "★★★★★".slice(0, Math.floor(rating)) + (rating % 1 ? "½" : "");
---

<section class="letterboxd-card border border-line bg-[#fbfaf6] px-5 py-5 lg:h-full lg:min-h-0 lg:overflow-hidden">
  <div class="flex items-center justify-between gap-4">
    <h2 class="font-mono text-[13px] uppercase tracking-[0.2em] text-ink/35">Recently watched</h2>
  </div>

  <div class="mt-3 grid grid-cols-3 gap-3">
    {movies.map((movie) => (
      <article class="min-w-0">
        <div class:list={["aspect-[2/3] w-full rounded-[3px]", movie.palette]} aria-hidden="true"></div>
        <div class="mt-2 min-w-0">
          <h3 class="truncate text-sm font-medium leading-none text-ink/70">{movie.title}</h3>
        </div>
        <div class="mt-2">
          <p class="whitespace-nowrap text-lg font-semibold leading-none text-[#b25332]" aria-label={`${movie.rating} stars`}>{stars(movie.rating)}</p>
        </div>
      </article>
    ))}
  </div>
</section>
